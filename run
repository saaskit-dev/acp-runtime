#!/bin/zsh
set -euo pipefail

if [[ $# -eq 0 ]]; then
  exec make help
fi

target="$1"
shift

case "$target" in
  runtime)
    if [[ $# -eq 0 ]]; then
      echo 'usage: ./run runtime <agent-id> [--sessions] [--load SESSION_ID] [--resume SESSION_ID] [--resume-last] [--resume-snapshot SNAPSHOT.json] [--prompt TEXT] [--log-file PATH] [--no-log-file] [prompt...]' >&2
      exit 2
    fi

    agent="$1"
    shift
    prompt=""
    log_file="${ACP_RUNTIME_LOG_FILE:-}"
    log_arg=""
    runtime_args=()

    while [[ $# -gt 0 ]]; do
      case "$1" in
        --sessions)
          runtime_args+=("$1")
          ;;
        --load=*)
          runtime_args+=("$1")
          ;;
        --load)
          shift
          runtime_args+=("--load=${1:-}")
          ;;
        --resume=*)
          runtime_args+=("$1")
          ;;
        --resume-last)
          runtime_args+=("$1")
          ;;
        --resume)
          shift
          runtime_args+=("--resume=${1:-}")
          ;;
        --resume-snapshot=*)
          runtime_args+=("$1")
          ;;
        --resume-snapshot)
          shift
          runtime_args+=("--resume-snapshot=${1:-}")
          ;;
        --prompt=*)
          prompt="${1#--prompt=}"
          ;;
        --prompt)
          shift
          prompt="${1:-}"
          ;;
        --log-file=*|--log=*)
          log_file="${1#*=}"
          log_arg="--log-file=$log_file"
          ;;
        --log-file|--log)
          shift
          log_file="${1:-}"
          log_arg="--log-file=$log_file"
          ;;
        --no-log-file)
          log_file=""
          log_arg="--no-log-file"
          ;;
        *)
          if [[ -n "$prompt" ]]; then
            prompt="$prompt $1"
          else
            prompt="$1"
          fi
          ;;
      esac
      shift
    done

    if [[ -n "$log_file" ]]; then
      export ACP_RUNTIME_LOG_FILE="$log_file"
    fi
    if [[ -n "$log_arg" ]]; then
      runtime_args+=("$log_arg")
    elif [[ -n "$log_file" ]]; then
      runtime_args+=("--log-file=$log_file")
    fi

    agent_id="$agent"
    if [[ "$agent_id" == "claude" ]]; then
      agent_id="claude-acp"
    elif [[ "$agent_id" == "codex" ]]; then
      agent_id="codex-acp"
    elif [[ "$agent_id" == "simulator" ]]; then
      agent_id="simulator-agent-acp-local"
    fi

    pnpm run build:self

    if [[ -n "$prompt" ]]; then
      exec node dist/examples/runtime-sdk-demo.js "$agent_id" "${runtime_args[@]}" "$prompt"
    fi

    exec node dist/examples/runtime-sdk-demo.js "$agent_id" "${runtime_args[@]}"
    ;;
  *)
    exec make "$target" "$@"
    ;;
esac
