#!/bin/zsh
set -euo pipefail

if [[ $# -eq 0 ]]; then
  exec make help
fi

target="$1"
shift

list_agents() {
  registry_url="https://cdn.agentclientprotocol.com/registry/v1/latest/registry.json"

  if command -v jq >/dev/null 2>&1 && registry_json="$(curl -fsSL "$registry_url" 2>/dev/null)"; then
    printf '%s\n' "$registry_json" \
      | jq -r '.agents[] | [.id, .name, .version] | @tsv'
    return
  fi

  node -e '
const registryUrl = "https://cdn.agentclientprotocol.com/registry/v1/latest/registry.json";
const response = await fetch(registryUrl);
if (!response.ok) {
  throw new Error(`Failed to fetch ACP registry: ${response.status} ${response.statusText}`);
}
const registry = await response.json();
for (const agent of registry.agents ?? []) {
  console.log(`${agent.id}\t${agent.name}\t${agent.version}`);
}
'
}

case "$target" in
  agents)
    list_agents
    ;;
  runtime)
    if [[ $# -gt 0 && "$1" == "--list-agents" ]]; then
      list_agents
      exit 0
    fi

    if [[ $# -eq 0 ]]; then
      echo 'usage: ./run runtime <agent-id> [--sessions] [--load SESSION_ID] [--resume SESSION_ID] [--resume-last] [--mode ID] [--model ID] [--effort LEVEL] [--initial-config-strict] [--system-prompt TEXT] [--system-prompt-file PATH] [--prompt TEXT] [--log-file PATH] [--no-log-file] [prompt...]' >&2
      echo '       ./run runtime --list-agents' >&2
      exit 2
    fi

    agent="$1"
    shift
    prompt=""
    log_file="${ACP_RUNTIME_LOG_FILE:-}"
    log_arg=""
    runtime_args=()

    while [[ $# -gt 0 ]]; do
      case "$1" in
        --sessions)
          runtime_args+=("$1")
          ;;
        --load=*)
          runtime_args+=("$1")
          ;;
        --load)
          shift
          runtime_args+=("--load=${1:-}")
          ;;
        --resume=*)
          runtime_args+=("$1")
          ;;
        --resume-last)
          runtime_args+=("$1")
          ;;
        --resume)
          shift
          runtime_args+=("--resume=${1:-}")
          ;;
        --resume-snapshot|--resume-snapshot=*)
          echo 'error: --resume-snapshot was removed; use --resume SESSION_ID or --resume-last' >&2
          exit 2
          ;;
        --config|--config=*)
          echo 'error: startup --config was removed; use --mode, --model, or --effort' >&2
          exit 2
          ;;
        --mode=*|--model=*|--effort=*)
          runtime_args+=("$1")
          ;;
        --mode|--model|--effort)
          option="$1"
          shift
          runtime_args+=("$option=${1:-}")
          ;;
        --initial-config-strict|--strict-initial-config)
          runtime_args+=("$1")
          ;;
        --system-prompt=*|--system-prompt-file=*)
          runtime_args+=("$1")
          ;;
        --system-prompt|--system-prompt-file)
          option="$1"
          shift
          runtime_args+=("$option=${1:-}")
          ;;
        --prompt=*)
          prompt="${1#--prompt=}"
          ;;
        --prompt)
          shift
          prompt="${1:-}"
          ;;
        --log-file=*|--log=*)
          log_file="${1#*=}"
          log_arg="--log-file=$log_file"
          ;;
        --log-file|--log)
          shift
          log_file="${1:-}"
          log_arg="--log-file=$log_file"
          ;;
        --no-log-file)
          log_file=""
          log_arg="--no-log-file"
          ;;
        --*)
          echo "warning: ignoring unknown option: $1" >&2
          ;;
        *)
          if [[ -n "$prompt" ]]; then
            prompt="$prompt $1"
          else
            prompt="$1"
          fi
          ;;
      esac
      shift
    done

    if [[ -n "$log_file" ]]; then
      export ACP_RUNTIME_LOG_FILE="$log_file"
    fi
    if [[ -n "$log_arg" ]]; then
      runtime_args+=("$log_arg")
    elif [[ -n "$log_file" ]]; then
      runtime_args+=("--log-file=$log_file")
    fi

    pnpm run build:self

    if [[ -n "$prompt" ]]; then
      exec node dist/examples/runtime-sdk-demo.js "$agent" "${runtime_args[@]}" "$prompt"
    fi

    exec node dist/examples/runtime-sdk-demo.js "$agent" "${runtime_args[@]}"
    ;;
  *)
    exec make "$target" "$@"
    ;;
esac
