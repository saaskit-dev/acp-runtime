{
  "version": 1,
  "id": "protocol.authenticate",
  "kind": "protocol",
  "title": "Authenticate",
  "description": "验证 agent 在 initialize 返回 authMethods 时，是否支持 authenticate。",
  "protocolDependencies": ["initialize", "authenticate"],
  "steps": [
    { "type": "initialize" },
    { "type": "authenticate", "skipIf": "!authMethods" }
  ],
  "assertions": [
    { "type": "transcript-has-method", "method": "initialize" },
    { "type": "transcript-has-method", "method": "authenticate" }
  ]
}
