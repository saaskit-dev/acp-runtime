{
  "version": 1,
  "id": "protocol.set-config-option",
  "kind": "protocol",
  "title": "Set Config Option",
  "description": "验证 agent 是否支持 session/set_config_option 并返回更新后的 configOptions。",
  "protocolDependencies": ["initialize", "session/new", "session/set_config_option"],
  "steps": [
    { "type": "initialize" },
    { "type": "session-new" },
    { "type": "set-config-option", "key": "verbose", "value": true }
  ],
  "assertions": [
    { "type": "transcript-has-method", "method": "session/set_config_option" }
  ]
}
