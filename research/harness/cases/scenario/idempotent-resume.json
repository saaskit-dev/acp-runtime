{
  "version": 1,
  "id": "scenario.idempotent-resume",
  "kind": "scenario",
  "title": "Idempotent Session Resume",
  "description": "验证 agent 对同一 session 连续执行两次 resume 不会崩溃。",
  "level": "P2",
  "protocolDependencies": ["session/new", "session/resume"],
  "steps": [
    { "type": "initialize" },
    { "type": "session-new" },
    { "type": "session-resume", "sessionRef": "current", "skipIf": "!capabilities.sessionCapabilities.resume" },
    { "type": "session-resume", "sessionRef": "current", "skipIf": "!capabilities.sessionCapabilities.resume" }
  ],
  "assertions": [
    { "type": "transcript-has-method", "method": "session/resume" }
  ]
}
