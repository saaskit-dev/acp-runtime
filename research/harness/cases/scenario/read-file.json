{
  "version": 1,
  "id": "scenario.read-file",
  "kind": "scenario",
  "title": "Read File",
  "description": "验证 agent 能触发文件读取相关交互路径。",
  "level": "P0",
  "protocolDependencies": ["session/new", "session/prompt", "session/update"],
  "steps": [
    { "type": "initialize" },
    { "type": "session-new" },
    { "type": "session-prompt", "prompt": "$probe-prompt", "defaultPrompt": "Read ./README.md and tell me the first heading.", "turnRef": "turn-1" },
    { "type": "wait-for-event", "eventType": "tool_call_update", "timeoutMs": 45000 }
  ],
  "assertions": [
    { "type": "transcript-has-method", "method": "session/prompt" },
    { "type": "transcript-has-event", "eventType": "tool_call_update" }
  ]
}
