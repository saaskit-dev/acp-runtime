{
  "name": "@saaskit-dev/simulator-agent-acp",
  "version": "0.1.1",
  "description": "Deterministic ACP simulator agent for client integration, protocol regression, and fault-injection testing.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "simulator-agent-acp": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist/index.js",
    "dist/index.d.ts",
    "dist/cli.js",
    "dist/cli.d.ts",
    "dist/simulator-agent.js",
    "dist/simulator-agent.d.ts",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "vitest run src/simulator-agent.test.ts"
  },
  "keywords": [
    "acp",
    "agent-client-protocol",
    "ai-agent",
    "simulator-agent",
    "testing",
    "regression",
    "fault-injection",
    "session"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.18.0"
  }
}

