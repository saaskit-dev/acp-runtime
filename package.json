{
  "name": "acp-runtime",
  "version": "0.1.0",
  "description": "High-level runtime for ACP (Agent Client Protocol) agents. Lifecycle management, turn serialization, state persistence, and a clean three-layer API.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "acp-simulator-agent": "dist/simulator-agent/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./simulator-agent": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "harness:clean-outputs": "node dist/harness/clean-outputs.js",
    "harness:run-agent": "node dist/harness/run-agent-matrix.js",
    "simulator-agent": "node dist/simulator-agent/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "acp",
    "agent-client-protocol",
    "ai-agent",
    "runtime",
    "session",
    "claude",
    "codex",
    "gemini"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "@agentclientprotocol/sdk": ">=0.18.0"
  },
  "devDependencies": {
    "@agentclientprotocol/sdk": "^0.18.0",
    "@types/node": "^22.15.3",
    "@types/tar": "^7.0.87",
    "@types/unzipper": "^0.10.11",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "tar": "^7.5.13",
    "unzipper": "^0.12.3"
  }
}
