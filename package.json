{
  "name": "@saaskit-dev/acp-runtime",
  "version": "0.1.1",
  "description": "Product-facing, product-agnostic ACP runtime with runtime agent launch helpers.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./internal/agent-launch-registry": {
      "types": "./dist/internal/agent-launch-registry.d.ts",
      "import": "./dist/internal/agent-launch-registry.js"
    },
    "./internal/simulator-workspace": {
      "types": "./dist/internal/simulator-workspace.d.ts",
      "import": "./dist/internal/simulator-workspace.js"
    }
  },
  "files": [
    "dist/index.js",
    "dist/index.d.ts",
    "dist/runtime",
    "dist/examples/client-sdk-demo.js",
    "dist/examples/client-sdk-demo.d.ts",
    "dist/examples/runtime-sdk-demo.js",
    "dist/examples/runtime-sdk-demo.d.ts",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "rm -rf dist packages/simulator-agent/dist .tmp harness-outputs .simulator-agent-acp-harness tmp-output.txt",
    "build": "pnpm --filter @saaskit-dev/simulator-agent-acp build && pnpm run build:self",
    "build:self": "pnpm run build:lib && pnpm run build:examples && pnpm run build:harness",
    "build:lib": "tsc -p tsconfig.json",
    "build:examples": "tsc -p tsconfig.examples.json",
    "build:harness": "tsc -p tsconfig.harness.json",
    "dev": "pnpm run build:lib -- --watch",
    "harness:clean-outputs": "node dist/harness/clean-outputs.js",
    "harness:check-admission": "node dist/harness/run-agent-matrix.js --gate admission",
    "harness:run-agent": "node dist/harness/run-agent-matrix.js --gate full",
    "predemo:client-sdk": "pnpm run build",
    "demo:client-sdk": "node dist/examples/client-sdk-demo.js",
    "predemo:runtime:claude": "pnpm run build",
    "demo:runtime:claude": "node dist/examples/runtime-sdk-demo.js claude-acp",
    "predemo:runtime": "pnpm run build",
    "demo:runtime": "node dist/examples/runtime-sdk-demo.js",
    "test": "pnpm --filter @saaskit-dev/simulator-agent-acp test && vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit -p tsconfig.json && pnpm run build:lib && tsc --noEmit -p tsconfig.examples.json && tsc --noEmit -p tsconfig.harness.json",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "acp",
    "agent-client-protocol",
    "ai-agent",
    "runtime",
    "testing",
    "regression",
    "fault-injection",
    "session",
    "claude",
    "codex",
    "gemini"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@types/tar": "^7.0.87",
    "@types/unzipper": "^0.10.11",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.18.0",
    "tar": "^7.5.13",
    "unzipper": "^0.12.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/saaskit-dev/acp-runtime.git"
  },
  "homepage": "https://github.com/saaskit-dev/acp-runtime#readme",
  "bugs": {
    "url": "https://github.com/saaskit-dev/acp-runtime/issues"
  }
}
