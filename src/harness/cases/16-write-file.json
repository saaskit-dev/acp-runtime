{
  "version": 1,
  "id": "scenario.write-file",
  "kind": "scenario",
  "probes": {
    "simulator-agent-acp-local": {
      "prompt": "/write /tmp/acp-harness-test.txt READY"
    }
  },
  "title": "Write File",
  "level": "P0",
  "protocolDependencies": [
    "session/new",
    "session/prompt",
    "session/update",
    "session/request_permission",
    "fs/write_text_file"
  ],
  "steps": [
    {
      "type": "initialize"
    },
    {
      "type": "session-new"
    },
    {
      "type": "permission-decision",
      "decision": "allow"
    },
    {
      "type": "session-prompt",
      "prompt": "$probe-prompt",
      "defaultPrompt": "Create ./tmp-output.txt containing the word READY.",
      "turnRef": "turn-1"
    },
    {
      "type": "wait-for-event",
      "eventType": "tool_call_update"
    }
  ],
  "assertions": [
    {
      "type": "transcript-has-method",
      "method": "session/prompt"
    },
    {
      "type": "transcript-has-method",
      "method": "session/request_permission"
    },
    {
      "type": "transcript-has-method",
      "method": "fs/write_text_file"
    },
    {
      "type": "transcript-has-event",
      "eventType": "tool_call_update"
    }
  ]
}
