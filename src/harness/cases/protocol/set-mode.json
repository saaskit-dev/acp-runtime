{
  "version": 1,
  "id": "protocol.set-mode",
  "kind": "protocol",
  "title": "Set Mode",
  "description": "验证 agent 是否支持在已有 session 上切换 mode。",
  "protocolDependencies": ["initialize", "session/new", "session/set_mode"],
  "steps": [
    { "type": "initialize" },
    { "type": "session-new" },
    { "type": "set-mode", "modeId": "$alternate", "skipIf": "!modes" }
  ],
  "assertions": [
    { "type": "transcript-has-method", "method": "session/set_mode" }
  ]
}
