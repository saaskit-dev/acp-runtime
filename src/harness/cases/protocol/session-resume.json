{
  "version": 1,
  "id": "protocol.session-resume",
  "kind": "protocol",
  "title": "Session Resume",
  "description": "验证 agent 是否支持基于已有 sessionId 执行 session/resume。",
  "protocolDependencies": ["initialize", "session/new", "session/resume"],
  "steps": [
    { "type": "initialize" },
    { "type": "session-new" },
    { "type": "session-resume", "sessionRef": "current", "skipIf": "!capabilities.sessionCapabilities.resume" }
  ],
  "assertions": [
    { "type": "transcript-has-method", "method": "session/resume" }
  ]
}
