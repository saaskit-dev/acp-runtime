{
  "version": 1,
  "id": "protocol.session-list",
  "kind": "protocol",
  "title": "Session List",
  "description": "验证 agent 在创建 session 后能列出可见 session。",
  "protocolDependencies": ["initialize", "session/new", "session/list"],
  "steps": [
    { "type": "initialize" },
    { "type": "session-new" },
    { "type": "session-list" }
  ],
  "assertions": [
    { "type": "transcript-has-method", "method": "session/list" }
  ]
}
