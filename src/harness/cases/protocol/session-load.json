{
  "version": 1,
  "id": "protocol.session-load",
  "kind": "protocol",
  "title": "Session Load",
  "description": "验证 agent 是否支持基于已有 sessionId 执行 session/load。",
  "protocolDependencies": ["initialize", "session/new", "session/load"],
  "steps": [
    { "type": "initialize" },
    { "type": "session-new" },
    { "type": "session-load", "sessionRef": "current", "skipIf": "!capabilities.sessionLoad" }
  ],
  "assertions": [
    { "type": "transcript-has-method", "method": "session/load" }
  ]
}
