{
  "version": 1,
  "id": "scenario.permission-denied",
  "kind": "scenario",
  "classification": {
    "opencode": {
      "assertionFailureStatus": "not-observed",
      "timeoutStatus": "not-observed"
    }
  },
  "title": "Permission Denied",
  "description": "验证 agent 在权限被拒绝时是否能以可观测方式收尾。",
  "level": "P1",
  "protocolDependencies": ["session/new", "session/prompt", "session/update", "session/request_permission"],
  "steps": [
    { "type": "initialize" },
    { "type": "session-new" },
    { "type": "permission-decision", "decision": "deny" },
    { "type": "session-prompt", "prompt": "Read ./README.md and tell me the first heading.", "turnRef": "turn-deny" },
    { "type": "wait-for-event", "eventType": "completed", "timeoutMs": 45000 }
  ],
  "assertions": [
    { "type": "transcript-has-method", "method": "session/request_permission" },
    { "type": "transcript-has-method", "method": "session/prompt" },
    { "type": "transcript-order", "first": "session/prompt", "then": "session/request_permission" }
  ]
}
