{
  "version": 1,
  "id": "scenario.read-file",
  "kind": "scenario",
  "probes": {
    "opencode": {
      "prompt": "Use the read tool to inspect ./README.md. Do not rely on prior context. After you have read the file, answer with only its first markdown heading."
    }
  },
  "title": "Read File",
  "level": "P0",
  "protocolDependencies": [
    "session/new",
    "session/prompt",
    "session/update"
  ],
  "steps": [
    {
      "type": "initialize"
    },
    {
      "type": "session-new"
    },
    {
      "type": "session-prompt",
      "prompt": "$probe-prompt",
      "defaultPrompt": "Read ./README.md and tell me the first heading.",
      "turnRef": "turn-1"
    },
    {
      "type": "wait-for-event",
      "eventType": "tool_call_update",
      "timeoutMs": 45000
    }
  ],
  "assertions": [
    {
      "type": "transcript-has-method",
      "method": "session/prompt"
    },
    {
      "type": "transcript-has-event",
      "eventType": "tool_call_update"
    }
  ]
}
