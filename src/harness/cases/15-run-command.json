{
  "version": 1,
  "id": "scenario.run-command",
  "kind": "scenario",
  "probes": {
    "simulator-agent-acp-local": {
      "prompt": "/bash pwd"
    },
    "opencode": {
      "prompt": "Use the execute tool to run `pwd`. Wait for the command output, then answer with only the resulting path."
    }
  },
  "title": "Run Command",
  "level": "P0",
  "protocolDependencies": [
    "session/new",
    "session/prompt",
    "session/update"
  ],
  "steps": [
    {
      "type": "initialize"
    },
    {
      "type": "session-new"
    },
    {
      "type": "permission-decision",
      "decision": "allow"
    },
    {
      "type": "session-prompt",
      "prompt": "$probe-prompt",
      "defaultPrompt": "Run `pwd` and tell me the resulting path.",
      "turnRef": "turn-1"
    },
    {
      "type": "wait-for-event",
      "eventType": "tool_call_update",
      "timeoutMs": 45000
    }
  ],
  "assertions": [
    {
      "type": "transcript-has-method",
      "method": "session/prompt"
    },
    {
      "type": "transcript-has-method",
      "method": "terminal/create"
    },
    {
      "type": "transcript-has-event",
      "eventType": "tool_call_update"
    }
  ]
}
